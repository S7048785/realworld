export com.yyjy.models.entity.Article
 -> package com.yyjy.models.entity.dto

ArticleSimple {
    id
    title
    desc
    author {
        id
        username
        avatar
    }
    likes
    views
    isLiked as isLike
    tags
    createdAt as created_at
}

ArticleEdit {
    title
    body
    tags
}


ArticleDetail {
    id
    title
    body
    author {
        id
        username
        avatar
    }
    likes
    tags
    isLike: Boolean? = false
    createdAt
    updatedAt
}

